{
  "manifest_version": 3,
  "name": "AI AI Bookmarks",
  "version": "0.1.3",
  "action": {},
  "options_page": "index.html",
  "permissions": ["bookmarks", "storage"],
  "background": {
    "service_worker": "src/background.ts"
  },
  "host_permissions": [
    "<all_urls>",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://api.proxyapi.ru/*"
  ],
  "icons": {
    "16": "logo-16.png",
    "48": "logo-48.png",
    "128": "logo-128.png"
  }
}
